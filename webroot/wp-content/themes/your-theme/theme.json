{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        {
          "slug": "ink",
          "name": "Ink",
          "color": "#0f172a"
        },
        {
          "slug": "slate",
          "name": "Slate",
          "color": "#1f2933"
        },
        {
          "slug": "amber",
          "name": "Amber",
          "color": "#f59e0b"
        },
        {
          "slug": "paper",
          "name": "Paper",
          "color": "#ffffff"
        },
        {
          "slug": "mist",
          "name": "Mist",
          "color": "#f5f7fa"
        }
      ]
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1120px"
    },
    "spacing": {
      "units": ["px", "rem", "vw", "%"]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "system-sans",
          "name": "System Sans",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--mist)",
      "text": "var(--wp--preset--color--slate)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--ink)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--ink)"
        }
      }
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)",
      "lineHeight": "1.6"
    }
  }
}
